{
  "id": "codebuddy",
  "platformId": "codebuddy",
  "version": "0.26.8",
  "apiVersion": 1,
  "minCoreVersion": "0.26.5",
  "displayName": "CodeBuddy",
  "entry": "runtime/index.json",
  "packageMode": "hotUpdate",
  "installKind": "sidecarAdapter",
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-codebuddy-adapter",
    "macosEntry": "adapter/macos/cockpit-codebuddy-adapter",
    "windowsEntry": "adapter/windows/cockpit-codebuddy-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-codebuddy-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.importJson",
      "accounts.importLocal",
      "accounts.addToken",
      "accounts.export",
      "accounts.indexPath",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.updateTags",
      "quota.alertPayload",
      "oauth.start",
      "oauth.complete",
      "oauth.cancel",
      "oauth.restorePendingListener",
      "switch.inject",
      "switch.injectDefaultProfile",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "tokenImport",
    "localImport",
    "switch",
    "quota",
    "runtime",
    "instances"
  ],
  "changelog": [
    {
      "version": "0.26.8",
      "date": "2026-06-30",
      "notes": [
        "Adds immutable platform package version history metadata so users can install, reinstall, update, or roll back to published package versions.",
        "Refreshes the platform package artifact for the main channel without replacing any previously published zip."
      ],
      "locales": {
        "zh-CN": {
          "notes": [
            "新增不可变的平台包版本历史元数据，用户可以安装、重新安装、更新或回退到已发布的平台包版本。",
            "刷新主通道平台包产物，同时不替换任何已发布过的旧 zip。"
          ]
        },
        "zh-TW": {
          "notes": [
            "新增不可變的平台包版本歷史中繼資料，使用者可以安裝、重新安裝、更新或回復到已發布的平台包版本。",
            "刷新主通道平台包產物，同時不替換任何已發布過的舊 zip。"
          ]
        }
      }
    },
    {
      "version": "0.26.7",
      "date": "2026-06-23",
      "notes": [
        "CodeBuddy account overview, multi-instance tabs, OAuth, token import, local import, switching, quota refresh, launch commands, and page interactions are now supplied by the CodeBuddy platform package.",
        "Core Shell keeps only CodeBuddy platform lifecycle controls, runtime gate, Host API, and adapter runner."
      ]
    }
  ],
  "contributions": {
    "platforms": [
      {
        "id": "codebuddy",
        "label": "CodeBuddy",
        "labelKey": "nav.codebuddy",
        "iconKey": "codebuddy",
        "page": "codebuddy"
      }
    ],
    "dataPaths": [
      "codebuddy_accounts.json",
      "codebuddy_accounts",
      "codebuddy_instances.json"
    ],
    "localStorageKeys": [
      "agtools.codebuddy.accounts.cache",
      "agtools.codebuddy.current_account_id",
      "agtools.codebuddy.flow_notice_collapsed",
      "agtools.codebuddy.instances.cache"
    ],
    "nativeBoundaries": []
  }
}
